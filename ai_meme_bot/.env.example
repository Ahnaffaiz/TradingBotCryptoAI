# Trading
TRADING_MODE=PAPER
BASE_TRADE_AMOUNT=0.1
DB_PATH=ai_meme_bot/database.db
ENTRY_SCORE_THRESHOLD=25
TRACKER_POLL_SECONDS=30
POSITION_REVIEW_SECONDS=45
REFLECTION_TIME=00:00
REFLECTION_TIMEZONE=Asia/Jakarta

# OpenAI-compatible AI provider for embedded Hermes
AI_PROVIDER=custom
AI_BASE_URL=https://provider.example/v1
AI_API_KEY=replace-me
AI_MODEL=replace-me

# External APIs
TELEGRAM_BOT_TOKEN=replace-me
# Powerful workspace operator. Keep disabled unless TELEGRAM_ADMIN_USER_IDS is set.
HERMES_OPERATOR_ENABLED=0
TELEGRAM_ADMIN_USER_IDS=
DEXSCREENER_PROFILE_URL=https://api.dexscreener.com/token-profiles/latest/v1
DEXSCREENER_TOKEN_URL=https://api.dexscreener.com/tokens/v1
SOLANA_RPC_URL=
HELIUS_RPC_URL=
# Optional X recent-search trend enrichment
X_BEARER_TOKEN=
X_RECENT_SEARCH_URL=https://api.x.com/2/tweets/search/recent
X_SEARCH_MINUTES=30
GECKOTERMINAL_TRENDING_URL=https://api.geckoterminal.com/api/v2/networks/solana/trending_pools

# Paper tracker filters
MIN_LIQUIDITY_USD=10000
MIN_PAIR_AGE_SECONDS=60

# Reserved real-trading values; v1 refuses REAL execution.
PRIVATE_KEY_BASE58=
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
